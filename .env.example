# SciWeave MCP Server — Environment Variables

# Required: API URLs for the SciWeave backends
# ML backend (FastAPI) — handles answer generation, semantic search
SCIWEAVE_ML_BACKEND_URL=https://nodes-api.desci.com

# Web app (Next.js) — handles lists, papers, chat history
SCIWEAVE_WEB_API_URL=https://sciweave.com

# Nodes API — handles auth, usage metering, subscriptions
SCIWEAVE_NODES_API_URL=https://nodes-api.desci.com

# For local development only: a SciWeave API key to use as default
# SCIWEAVE_API_KEY=your_api_key_here

# Optional: log outgoing MCP HTTP requests and response statuses in the dev server
# SCIWEAVE_MCP_DEBUG_HTTP=true
